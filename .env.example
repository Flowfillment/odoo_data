# Odoo Online 17 connection settings.
# Copy this file to `.env` and fill in your values. `.env` is gitignored.

# Base URL of your Odoo Online instance (no trailing /jsonrpc).
ODOO_URL=https://yourcompany.odoo.com

# Database name. For Odoo Online this is usually your subdomain
# (e.g. "yourcompany" for yourcompany.odoo.com).
ODOO_DB=yourcompany

# Login email of the user the API acts as.
ODOO_USERNAME=you@example.com

# API key generated under Preferences -> Account Security -> New API Key.
# Used in place of the account password for the external API.
ODOO_API_KEY=your_api_key_here
